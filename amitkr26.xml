  <!-- SCRIPTS (upgraded; safe guards + persistent theme & color) -->
  <script type='text/javascript'>
    <![CDATA[
    (function(){
      // Theme toggle - preserves original .dark behavior but uses localStorage
      var themeBtn = document.querySelector('.toggle-theme');
      try{
        var savedTheme = localStorage.getItem('amit_theme');
        if(savedTheme === 'dark'){
          document.body.classList.add('dark');
          if(themeBtn) themeBtn.setAttribute('aria-pressed','true');
        } else {
          if(themeBtn) themeBtn.setAttribute('aria-pressed','false');
        }
      }catch(e){/* no-op */}

      if(themeBtn){
        themeBtn.addEventListener('click', function(e){
          e.preventDefault();
          var isDark = document.body.classList.toggle('dark');
          try{
            localStorage.setItem('amit_theme', isDark ? 'dark' : 'light');
            themeBtn.setAttribute('aria-pressed', isDark ? 'true' : 'false');
          }catch(err){}
        },{passive:true});
      }

      // Mobile navigation toggle - toggles existing nav without removing it
      var mobileToggle = document.querySelector('.mobile-nav-toggle');
      var nav = document.getElementById('site-nav');
      function setNavVisibility(show){
        if(!nav) return;
        if(show){
          nav.style.display = 'flex';
          nav.setAttribute('aria-hidden','false');
          mobileToggle.setAttribute('aria-expanded','true');
        } else {
          nav.style.display = '';
          nav.setAttribute('aria-hidden','true');
          mobileToggle.setAttribute('aria-expanded','false');
        }
      }
      // initialize responsive state
      function updateNavOnResize(){
        if(window.innerWidth <= 768){
          // hide nav by default on small screens (but keep it accessible via toggle)
          if(nav) nav.style.display = 'none';
          if(mobileToggle) mobileToggle.style.display = 'inline-flex';
        } else {
          if(nav) nav.style.display = 'flex';
          if(mobileToggle) mobileToggle.style.display = 'none';
        }
      }
      updateNavOnResize();
      window.addEventListener('resize', updateNavOnResize);

      if(mobileToggle){
        mobileToggle.addEventListener('click', function(e){
          e.preventDefault();
          if(!nav) return;
          var isShown = nav.style.display === 'flex';
          setNavVisibility(!isShown);
        },{passive:true});
      }

      // Color switcher - sets --primary and persists
      function applyColorFromStorage(){
        try{
          var c = localStorage.getItem('amit_primary_color');
          if(c){
            document.documentElement.style.setProperty('--primary', c);
          }
        }catch(e){}
      }
      applyColorFromStorage();

      window.setColor = function(c){
        try{
          document.documentElement.style.setProperty('--primary', c);
          localStorage.setItem('amit_primary_color', c);
        }catch(e){}
      };

      // Improve in-page anchor smooth scrolling (for internal links)
      document.querySelectorAll('a[href^="#"]').forEach(function(a){
        a.addEventListener('click', function(e){
          var href = this.getAttribute('href');
          if(href && href.length > 1){
            var id = href.slice(1);
            var el = document.getElementById(id);
            if(el){
              e.preventDefault();
              el.scrollIntoView({behavior:'smooth',block:'start'});
              try{ history.replaceState && history.replaceState(null, null, '#'+id); }catch(e){}
              if(window.innerWidth <= 768 && nav){
                // hide mobile nav after selecting link
                nav.style.display = 'none';
              }
            }
          }
        }, {passive:true});
      });

      // small accessibility improvement: ensure contact form buttons are focusable
      try{
        var contactButtons = document.querySelectorAll('.contact-form-button');
        contactButtons.forEach(function(b){ b.setAttribute('tabindex','0'); });
      }catch(e){}
    })();
    ]]>
  </script>

  <!-- Keep analytics include (unchanged) -->
  <b:include data='blog' name='google-analytics'/>
</body>
